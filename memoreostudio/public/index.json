r (let btn of buttons) {\n    btn.style.background = '#f4f4f4';\n    btn.style.color = 'black';\n  }\n  event.currentTarget.style.background = '#333';\n  event.currentTarget.style.color = 'white';\n}\n\u003c/script\u003e","description":"Capture the feeling, keep the memory. With Memoreo. London-based Portrait \u0026 Lifestyle Photographer","image":null,"permalink":"http://localhost:1313/gallery/","title":"My Portfolio"}]